# Exemplo de variáveis de ambiente
# Copie para .env.local (dev) ou configure no Amplify Console (produção)

# API base URL — deixe vazio em dev (Vite proxy faz o roteamento)
# Em produção: https://api.arquivoseg.com.br
VITE_API_BASE_URL=

# Define 'false' para usar o backend real; 'true' para dados locais (mock)
VITE_ENABLE_MOCK=true

VITE_APP_NAME="ArquivoSeg - Gestão de Sinistros"

# Zitadel OIDC — obtenha o client_id no console Zitadel (aplicação SPA)
# Em dev sem backend: deixe em branco (mock mode não requer OIDC)
VITE_ZITADEL_AUTHORITY=https://auth.arquivoseg.com.br
VITE_ZITADEL_CLIENT_ID=
